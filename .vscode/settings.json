{
  "git.repositoryUrl": "https://github.com/vasivandrij656-arch/atlastrinity.git",
  "git.autofetch": true,
  "git.user.email": "oleg1203@gmail.com",
  "git.user.name": "Oleg Kizyma",
  "github.auth": "usingToken",
  "github.gitCredentialHelper": true,
  "github.enterpriseUri": "${env:GITHUB_TOKEN}",
  "[python]": {
    "editor.defaultFormatter": "ms-python.python",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true
  },
  "editor.rulers": [
    80,
    120
  ],
  "editor.wordWrap": "on",
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/node_modules": true,
    "**/.pytest_cache": true
  },
  "search.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/node_modules": true,
    "**/build": true,
    "**/vendor": true
  },
  "python.linting.enabled": true,
  "python.linting.ruffEnabled": true,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests"
  ],
  "extensions.recommendations": [
    "ms-python.python",
    "ms-python.vscode-pylance",
    "charliermarsh.ruff",
    "biomejs.biome",
    "eamodio.gitlens",
    "GitHub.copilot"
  ],
  "yaml.schemas": {
    "https://json.schemastore.org/github-action": [
      ".github/actions/*/action.yml",
      ".github/actions/*/action.yaml"
    ],
    "https://json.schemastore.org/github-workflow": [
      ".github/workflows/*.yml",
      ".github/workflows/*.yaml"
    ]
  }
}