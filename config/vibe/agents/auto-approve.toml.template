# Auto-approve agent configuration for Vibe
# Full automation: ALL tools auto-approved without confirmation

active_model = "gpt-4o"
auto_approve = true
system_prompt_id = "cli"
confirmation_timeout_s = 5

[tools.bash]
permission = "always"
allowlist = ["*"]

[tools.write_file]
permission = "always"
allowlist = ["/tmp/*", "/Users/dev/Documents/GitHub/atlastrinity/*"]

[tools.read_file]
permission = "always"

[tools.grep]
permission = "always"

[tools.search_replace]
permission = "always"

[tools.ls]
permission = "always"

# MCP Tools
[tools.devtools_devtools_lint_python]
permission = "always"

[tools.devtools_devtools_run_global_lint]
permission = "always"
