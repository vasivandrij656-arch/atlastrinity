# Accept-edits agent configuration for Vibe
# Auto-approves file reads/writes; bash requires confirmation

active_model = "gpt-4.1"
system_prompt_id = "cli"
confirmation_timeout_s = 20

# File tools — auto-approved for applying edits
[tools.read_file]
permission = "always"

[tools.write_file]
permission = "always"

[tools.search_replace]
permission = "always"

[tools.grep]
permission = "always"

[tools.ls]
permission = "always"

# Shell execution — auto-approved per user request (high speed, "all-in")
[tools.bash]
permission = "always"


# MCP Tools — lint after edits
[tools.devtools_devtools_lint_python]
permission = "always"

[tools.devtools_devtools_run_global_lint]
permission = "always"
