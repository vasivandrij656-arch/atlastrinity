# =============================================================================
# VIBE CLI CONFIGURATION
# =============================================================================
# Vibe is a code editor agent that uses LLM providers for code assistance
# Official documentation: https://docs.mistral.ai/mistral-vibe/introduction/configuration

# =============================================================================
# ACTIVE MODEL SELECTION
# =============================================================================
# Choose ONE active model based on your provider:
#
# === FOR COPILOT PROVIDER ===
# active_model = "gpt-4.1"           # Latest GPT-4 model
# active_model = "gpt-4o"            # GPT-4o (multimodal)
# active_model = "grok-code-fast-1"  # Fast coding analysis
# active_model = "claude-haiku-4.5"  # 🚀 Premium: Claude Haiku 4.5 (200K context)
# active_model = "gemini-flash-3-preview" # 🚀 Premium: Gemini Flash 3 (1M context)
#
# === FOR WINDSURF PROVIDER ===
# active_model = "claude-4.6-opus"    # 🚀 NEW: Ultra-Advanced Reasoning
# active_model = "gpt-5.2-codex"      # 🚀 NEW: 4 levels of reasoning
# active_model = "swe-1.5"            # Best agentic model (near Claude 4.5)
# active_model = "llama-3.1-405b"     # Windsurf Premier flagship
# active_model = "gemini-3-pro"       # Free general purpose
# active_model = "deepseek-v3"        # Free general purpose
#
# === FALLBACK CHAIN ===
# Models to try if active_model fails (in order)
# Optimized for Copilot + Windsurf hybrid usage
# NOTE: This is for VIBE only - NOT system reasoning!
# System reasoning uses oswe-vscode-secondary from config.yaml
# Complexity-aware fallback: premium models first, then standard, then lightweight
fallback_chain = [\"gpt-4o\", \"gpt-4.1\", \"claude-haiku-4.5\", \"gemini-flash-3-preview\", \"oswe-vscode-secondary\", \"grok-code-fast-1\"]

# Current selection (change based on your provider):
active_model = "gpt-4o"            # GPT-4o (Stable Primary)

# System prompt ID (refers to file in ~/.vibe/prompts/ cli.md by default)
system_prompt_id = "cli"

# Default operational mode (default, plan, accept-edits, auto-approve)
default_mode = "auto-approve"

# Enable/Disable auto-updates
enable_auto_update = true

# Execution limits
max_turns = 100

# Working directory (centralized for workspace boundary alignment)
workspace = "${CONFIG_ROOT}/workspace"

# =============================================================================
# Tool Availability Patterns
# =============================================================================
# Exact names, glob patterns, or re: prefix for regex
enabled_tools = [] # Empty = all enabled
disabled_tools = [] # No tools disabled

# =============================================================================
# Provider Configuration
# =============================================================================
[[providers]]
name = "mistral"
api_base = "https://api.mistral.ai/v1"
api_key_env_var = "MISTRAL_API_KEY"
api_style = "mistral"
backend = "mistral"

[[providers]]
name = "openrouter"
api_base = "https://openrouter.ai/api/v1"
api_key_env_var = "OPENROUTER_API_KEY"
api_style = "openai"
backend = "generic"

[[providers]]
name = "copilot"
api_base = "http://127.0.0.1:8086"
api_key_env_var = "COPILOT_SESSION_TOKEN"
api_style = "openai"
backend = "generic"
requires_proxy = true
proxy_command = "python3 ${PROJECT_ROOT}/src/providers/proxy/copilot_vibe_proxy.py"
requires_token_exchange = true

[[providers]]
name = "windsurf"
api_base = "http://127.0.0.1:8085"
api_key_env_var = "WINDSURF_API_KEY"
api_style = "openai"
backend = "generic"
requires_proxy = true
proxy_command = "python3 ${PROJECT_ROOT}/src/providers/proxy/vibe_windsurf_proxy.py"
requires_token_exchange = false

