{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["src/main/main.ts", "src/main/preload.ts", "src/renderer/main.tsx"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["dist/**", "node_modules/**"],
  "ignoreDependencies": [
    "ajv",
    "@modelcontextprotocol/*",
    "chrome-devtools-mcp",
    "cloudinary",
    "stripe",
    "tailwindcss",
    "@eslint/js",
    "eslint-plugin-react",
    "eslint-plugin-react-hooks",
    "typescript-eslint"
  ],
  "ignoreBinaries": ["unset", "open", "sleep", "jq"],
  "eslint": false
}
